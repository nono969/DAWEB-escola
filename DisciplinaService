package br.edu.ifpb.escola.business.service;

import br.edu.ifpb.escola.business.dto.DisciplinaDTO;
import br.edu.ifpb.escola.model.entity.Disciplina;
import br.edu.ifpb.escola.model.entity.Estudante;
import br.edu.ifpb.escola.repository.DisciplinaRepository;
import br.edu.ifpb.escola.repository.EstanteRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import java.util.List;
import java.util.Optional;

@Service
public class DisciplinaService {

    @Autowired
    private DisciplinaRepository repository;

    @Autowired
    private EstanteRepository estanteRepository;

    @Autowired
    private PrinterService printer;

    @Autowired
    private ValidationService validationService;

    public void cadastrar(DisciplinaDTO dto) {
        if (!validationService.isDisciplinaValida(dto, printer)) return;
        if (repository.findByCod(dto.getCod()).isPresent()) {
            printer.erro("Já existe uma disciplina com este código!");
            return;
        }
        Disciplina disciplina = new Disciplina(dto.getNome(), dto.getProfessor(), dto.getCargaHoraria());
        disciplina.setCod(dto.getCod());
        repository.save(disciplina);
        printer.sucesso("Disciplina " + disciplina.getNome() + " cadastrada com sucesso!");
    }

    public DisciplinaDTO buscar(int codigo) {
        Optional<Disciplina> optional = repository.findByCod(codigo);
        if (optional.isEmpty()) {
            printer.erro("Disciplina com código " + codigo + " não encontrada!");
            return null;
        }
        Disciplina d = optional.get();
        return new DisciplinaDTO(d.getCod(), d.getNome(), d.getProfessor(), d.getCargaHoraria());
    }

    public void exibirDisciplina(int codigo) {
        DisciplinaDTO dto = buscar(codigo);
        if (dto != null) printer.imprimirDisciplina(dto);
    }

    public void exibirDisciplinaComAlunos(int codigo) {
        Optional<Disciplina> optional = repository.findByCod(codigo);
        if (optional.isPresent()) {
            printer.listarDisciplinaComAlunos(optional.get());
        } else {
            printer.erro("Disciplina não encontrada!");
        }
    }

    public void editar(DisciplinaDTO dto) {
        if (!validationService.isDisciplinaValida(dto, printer)) return;
        Optional<Disciplina> optional = repository.findByCod(dto.getCod());
        if (optional.isEmpty()) {
            printer.erro("Disciplina não encontrada!");
            return;
        }
        Disciplina existente = optional.get();
        existente.setNome(dto.getNome());
        existente.setProfessor(dto.getProfessor());
        existente.setCargaHoraria(dto.getCargaHoraria());
        repository.save(existente);
        printer.sucesso("Disciplina atualizada com sucesso!");
    }

    public void matricularEstudante(int codigoDisciplina, Estudante estudante) {
        Optional<Disciplina> optional = repository.findByCod(codigoDisciplina);
        if (optional.isEmpty()) {
            printer.erro("Disciplina não encontrada!");
            return;
        }
        if (estudante == null) {
            printer.erro("Estudante não encontrado!");
            return;
        }
        Disciplina disciplina = optional.get();
        disciplina.addEstudante(estudante);
        estudante.setD(disciplina);
        estanteRepository.save(estudante);
        printer.sucesso(estudante.getNome() + " matriculado em " + disciplina.getNome() + " com sucesso!");
    }

    public boolean existeDisciplina(int codigo) {
        return repository.findByCod(codigo).isPresent();
    }

    public void exibirLista() {
        List<Disciplina> disciplinas = repository.findAll();
        printer.listarDisciplinas(disciplinas);
    }
}
